{
  "appId": "com.rededor.appqualidade",
  "productName": "App Qualidade",
  "directories": {
    "output": "release"
  },
  "publish": {
    "provider": "github",
    "owner": "bumasello",
    "repo": "appqualidade"
  },
  "files": [
    "dist-electron/**/*",
    "frontend/dist/**/*",
    "backend/dist/**/*",
    "backend/node_modules/oracledb/**/*",
    "resources/**/*",
    "package.json"
  ],
  "asarUnpack": [
    "backend/dist/**/*",
    "backend/node_modules/oracledb/**/*"
  ],
  "extraResources": [
    {
      "from": "resources/instantclient_19_30",
      "to": "instantclient_19_30",
      "filter": ["**/*"]
    },
    {
      "from": ".env.prd",
      "to": ".env.app"
    }
  ],
  "win": {
    "target": [
      {
        "target": "nsis",
        "arch": ["x64"]
      }
    ],
    "icon": "build/favicon.png"
  },
  "nsis": {
    "oneClick": false,
    "perMachine": false,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "shortcutName": "App Qualidade"
  }
}
