{
  "name": "app-qualidade-dados",
  "version": "1.0.0",
  "description": "Aplicativo desktop para qualidade e curadoria de dados com Electron, React e Express.",
  "author": "Bruno Masello <bruno.masello@rededor.com.br>",
  "main": "dist-electron/main.js",
  "type": "module",
  "scripts": {
    "build:electron": "esbuild electron/main.ts --bundle --platform=node --external:electron --outfile=dist-electron/main.js --format=esm",
    "build:react": "cd frontend && bun run build",
    "build:backend": "cd backend && bunx tsc",
    "dev:electron": "bun run build:electron && bun run build:react && bun run build:backend && electron dist-electron/main.js",
    "dev:react": "cd frontend && bun run dev",
    "dev:backend": "cd backend && bun run dev",
    "build": "bun run build:electron && bun run build:react && bun run build:backend",
    "dist": "bun run build && electron-builder --windows"
  },
  "dependencies": {},
  "devDependencies": {
    "electron": "^31.0.9",
    "electron-builder": "^26.0.12",
    "esbuild": "^0.25.5"
  },
  "build": {
    "appId": "com.rededor.appqualidade",
    "productName": "App Qualidade",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist-electron/**/*",
      "frontend/dist/**/*",
      "backend/dist/**/*",
      "resources/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "resources/instantclient_19_6",
        "to": "instantclient_19_6",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/favicon.png"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "App Qualidade"
    }
  }
}
