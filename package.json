{
  "name": "app-qualidade-dados",
  "version": "1.4.0",
  "description": "Aplicativo desktop para qualidade e curadoria de dados com Electron, React e Express.",
  "author": "Bruno Masello <bruno.masello@rededor.com.br>",
  "main": "dist-electron/main.cjs",
  "type": "module",
  "scripts": {
    "build:electron": "esbuild electron/main.ts --bundle --platform=node --external:electron --external:electron-updater --outfile=dist-electron/main.cjs --format=cjs",
    "build:react": "cd frontend && bun run build",
    "build:backend": "esbuild backend/src/server.ts --bundle --platform=node --external:oracledb --outfile=backend/dist/server.js",
    "dev:electron": "bun run build:electron && bun run build:react && bun run build:backend && electron dist-electron/main.cjs",
    "dev:react": "cd frontend && bun run dev",
    "dev:backend": "cd backend && bun run dev",
    "build": "bun run build:electron && bun run build:react && bun run build:backend",
    "dist": "bun run build && electron-builder --windows",
    "dist:prd": "bun run build && electron-builder --windows --config electron-builder.prd.json --publish always",
    "dist:hml": "bun run build && electron-builder --windows --config electron-builder.hml.json --publish always"
  },
  "dependencies": {
    "baseline-browser-mapping": "^2.10.32",
    "caniuse-lite": "^1.0.30001793",
    "dotenv": "^17.4.2",
    "electron-updater": "^6.8.3"
  },
  "devDependencies": {
    "electron": "^31.0.9",
    "electron-builder": "^26.0.12",
    "esbuild": "^0.25.5"
  },
  "build": {
    "appId": "com.rededor.appqualidade",
    "productName": "App Qualidade",
    "directories": {
      "output": "release"
    },
    "publish": {
      "provider": "github",
      "owner": "bumasello",
      "repo": "appqualidade"
    },
    "files": [
      "dist-electron/**/*",
      "frontend/dist/**/*",
      "backend/dist/**/*",
      "resources/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "backend/dist/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/favicon.png"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "App Qualidade"
    }
  }
}
